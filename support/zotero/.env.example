# Zotero Web API credentials — copia para `.env` e preenche.
# `.env` está gitignored; este `.env.example` fica versionado como template.
#
# Como obter:
# 1. Vai a https://www.zotero.org/settings/security#applications
# 2. "Create new private key" — escolhe permissões (read-only basta para sync.mjs;
#    write apenas se quiseres usar zotero-write.mjs no futuro)
# 3. Cola a chave aqui e o teu userID (visível na mesma página)

ZOTERO_API_KEY=
ZOTERO_USER_ID=
